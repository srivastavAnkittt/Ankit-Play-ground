        "label": "Days"
      },
      {
        "type": "text",
        "id": "hour",
        "label": "Hours"
      },
      {
        "type": "text",
        "id": "minutes",
        "label": "Minute"
      },
      {
        "type": "text",
        "id": "second",
        "label": "Second"
      }
    ],
    "presets": [
      {
        "name": "Timer"
      }
    ]
  }
{% endschema %}